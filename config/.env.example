# ENLA 2026 Callao Pipeline Configuration
# Copy this file to .env and fill in the values
# For detailed setup instructions, see CREDENTIALS_SETUP.md

# ==========================================
# MongoDB Configuration (Required)
# ==========================================
# MongoDB connection string (MongoDB Atlas or local)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Get this from: MongoDB Atlas > Database > Connect > Drivers > Connection String
MONGODB_URI=

# ==========================================
# GCP Configuration (Required)
# ==========================================
# Google Cloud Platform project ID
# Get this from: Google Cloud Console > Project Selector (top bar)
GCP_PROJECT_ID=

# Path to GCP service account credentials JSON file
# Download from: GCP Console > IAM & Admin > Service Accounts > Keys > Add Key
# Example: /path/to/service-account-key.json (Linux/Mac)
# Example: C:\Users\YourUser\credentials\gcp-key.json (Windows)
GCP_CREDENTIALS_PATH=

# ==========================================
# Logging Configuration (Optional)
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# Alert Configuration (Required)
# ==========================================
# Email address for sending alerts (must be verified in SendGrid)
# This should match the sender you verified in SendGrid Single Sender Verification
ALERT_EMAIL_FROM=enla-alerts@dre-callao.gob.pe

# Comma-separated list of email recipients for alerts
# Example: admin@dre-callao.gob.pe,principal@school.edu.pe
# Leave empty if configuring via GitHub Actions input parameter
ALERT_EMAIL_TO=

# SendGrid API key for email delivery
# Get this from: SendGrid > Settings > API Keys > Create API Key
# Format: SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=

# ==========================================
# Advanced Configuration (Optional)
# ==========================================
# BigQuery Dataset ID (default: BI_ENLA)
# GCP_DATASET_ID=BI_ENLA

# BigQuery Dataset Location (default: US)
# GCP_LOCATION=US

# MongoDB Database Name (default: enla_db)
# MONGODB_DB=enla_db

# MongoDB Collection for Raw Data (default: enla_callao_raw)
# MONGODB_COLLECTION_RAW=enla_callao_raw

# MongoDB Collection for Ingestion Log (default: enla_ingestion_log)
# MONGODB_COLLECTION_LOG=enla_ingestion_log

# ENLA Region (default: CALLAO)
# ENLA_REGION=CALLAO

# ENLA Grade to process (default: 2)
# ENLA_GRADO=2

# Target score threshold for pass/fail (default: 60.0)
# TARGET_SCORE_THRESHOLD=60.0

# Risk thresholds for alerts (default: 0.7 high, 0.5 medium)
# ALERT_RISK_THRESHOLD_HIGH=0.7
# ALERT_RISK_THRESHOLD_MEDIUM=0.5
