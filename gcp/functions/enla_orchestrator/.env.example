# ENLA 2026 Callao - Cloud Function Environment Variables
# Copy this file to .env and fill in the values

# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_DATASET_ID=BI_ENLA
GCP_LOCATION=US
GCP_CREDENTIALS_PATH=/path/to/service-account.json

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@host:port/
MONGODB_DB=enla_db
MONGODB_COLLECTION_RAW=enla_callao_raw
MONGODB_COLLECTION_LOG=enla_ingestion_log

# Alert Configuration
ALERT_RISK_THRESHOLD_HIGH=0.7
ALERT_RISK_THRESHOLD_MEDIUM=0.5
ALERT_EMAIL_FROM=enla-alerts@dre-callao.gob.pe
ALERT_EMAIL_TO=recipient1@dre-callao.gob.pe,recipient2@dre-callao.gob.pe
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/tmp/enla_pipeline.log
LOG_FORMAT=json

# Feature Engineering Configuration
TARGET_SCORE_THRESHOLD=60.0
FEATURE_NORMALIZATION_MIN=-1.0
FEATURE_NORMALIZATION_MAX=1.0

# Model Configuration
MODEL_RANDOM_STATE=42
MODEL_TEST_SIZE=0.2
MODEL_TRAIN_YEARS=2021,2022
MODEL_TEST_YEARS=2023

# ENLA Data Configuration
ENLA_REGION=CALLAO
ENLA_GRADO=2
ENLA_YEARS=2021,2022,2023
